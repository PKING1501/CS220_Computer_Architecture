xst -intstyle ise -ifn "/users/btech/pk/Documents/Lab3_2/R_LED/R_LED.xst" -ofn "/users/btech/pk/Documents/Lab3_2/R_LED/R_LED.syr" 
ngdbuild -intstyle ise -dd _ngo -nt timestamp -uc R_LED.ucf -p xc3s500e-fg320-4 R_LED.ngc R_LED.ngd  
